{
  "expo": {
    "name": "JodTod",
    "slug": "JodTodApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "jodtod",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jodtod.app"
    },
    "android": {
      "package": "com.jodtod.app",
      "adaptiveIcon": {
        "backgroundColor": "#6366f1",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {
        "origin": "https://jodtod.co.in"
      },
      "eas": {
        "projectId": "d0ffc913-61e9-493f-9243-10c7d3d47ed8"
      }
    },
    "owner": "jasscodetools"
  }
}
